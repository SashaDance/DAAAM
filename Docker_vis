FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    pkg-config \
    python3-dev \
    libeigen3-dev \
    nlohmann-json3-dev \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip setuptools wheel && \
    python -m pip install \
      numpy \
      scipy \
      pyyaml \
      python-dotenv \
      rerun-sdk==0.23.1 \
      "pybind11<3" \
      scikit-build-core

RUN git clone --branch project/daaam https://github.com/MIT-SPARK/Spark-DSG.git /tmp/Spark-DSG && \
    python -m pip install --no-build-isolation /tmp/Spark-DSG && \
    rm -rf /tmp/Spark-DSG

WORKDIR /workspace
ENV PYTHONPATH=/workspace/src

CMD ["bash"]
